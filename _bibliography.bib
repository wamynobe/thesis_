%how to deal with tone 3 sandhi in verb reduplication and lexical compounds
@article{gao2021processing,
  author   = {Gao, Feier  and Lyu, Siqi  and Lin, Chien-Jer Charles },
  title    = {Processing Mandarin Tone 3 Sandhi at the Morphosyntactic Interface: Reduplication and Lexical Compounds},
  journal  = {Frontiers in Psychology},
  volume   = {Volume 12 - 2021},
  year     = {2021},
  url      = {https://www.frontiersin.org/journals/psychology/articles/10.3389/fpsyg.2021.713665},
  doi      = {10.3389/fpsyg.2021.713665},
  issn     = {1664-1078},
  abstract = {Mandarin tone 3 sandhi is a phonological alternation in which the initial tone 3 (i.e., low tone) syllable changes to a tone 2 (i.e., rising tone) when followed by another tone 3. The present study used a cross-modal syllable-morpheme matching experiment to examine how native speakers process the sandhi sequences derived from verb reduplication and compounding, respectively. Embedded in a visually-presented sentential context, a disyllabic sequence containing a sandhi target was displayed simultaneously with a monosyllabic audio, either a tone 1 (i.e., high-level tone), tone 2 (i.e., rising tone) or tone 3 (i.e., low tone), and participants judged whether the audio syllable matched with the visual morpheme. Results showed that the tone 3 sandhi was processed differently in the two constructions. The underlying and the surface tone were co-activated and competed with each other in sandhi compounds whereas predominant activation of the underlying tone, over the surface tone, was observed in reduplication. The processing of tone 3 sandhi offers support for distinctive morphological structures: a lexical compound is represented both as a whole-word unit and as a combination of two individual morphemes whereas a verb reduplication is represented and accessed as a monomorphemic unit in the mental lexicon.}
}

%L2 learners có low productivity với T3 sandhi
%nhưng không có pattern tương tự với Half-T3 sandhi
@article{qin2022sandhi,
title = {The Second-Language Productivity of Two Mandarin Tone Sandhi Patterns},
journal = {Speech Communication},
volume = {138},
pages = {98-109},
year = {2022},
issn = {0167-6393},
doi = {https://doi.org/10.1016/j.specom.2022.02.009},
url = {https://www.sciencedirect.com/science/article/pii/S0167639322000322},
author = {Zhen Qin},
keywords = {Productivity, wug test, third tone sandhi (T3 sandhi), half-T3 sandhi, second-language proficiency},
abstract = {This study investigates whether the phonetic motivation of two Mandarin tone sandhi patterns influences second-language (L2) learners’ productivity in novel words. Research has suggested that the Mandarin third tone sandhi (T3 sandhi) and Half-T3 sandhi might pose different learning challenges for L2 learners, but there is no evidence that phonetic motivation influences L2 learners’ productive application of the tone sandhi rules. This study re-examines L2 learners’ productive application of the two sandhi patterns and further tests whether their productivity patterns change with increasing Mandarin proficiency. Native Mandarin speakers and Korean-speaking learners of Mandarin with high and low proficiency levels completed a wug production experiment that included both real and novel Mandarin disyllabic words. The results of a comparison of real and novel words showed a low productivity of the T3 sandhi among the L2 learners, but no such pattern was found for the Half-T3 sandhi. The differences in the productivity of the two sandhi patterns for L2 learners did not change with increasing Mandarin proficiency, although there was a difference in the production of novel words involving the T3 sandhi, which may be explained by improved metalinguistic knowledge. These results indicated the relevance of phonetic motivation to L2 productivity of the tone sandhi patterns in Mandarin.}
}

